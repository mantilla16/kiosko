# =====================================================
#  Configuración del Sistema del Kiosco
#  Copia este archivo como ".env" y ajusta los valores
# =====================================================

# Cadena de conexión a PostgreSQL (la base de datos vive en el mismo servidor)
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_BD?schema=public
DATABASE_URL="postgresql://kiosco:cambia_esta_clave@localhost:5432/kiosco?schema=public"

# Puerto donde escucha el servidor web
PORT=3000

# Secreto para firmar los tokens de sesión (JWT). OBLIGATORIO.
# Genera uno propio (NO uses el de ejemplo) con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=pon_aqui_un_secreto_largo_y_aleatorio

# Duración de la sesión (ej: 24h, 12h, 7d)
JWT_EXPIRES_IN=24h

# Orígenes permitidos para CORS (separados por coma). Vacío = solo mismo origen.
CORS_ORIGIN=
